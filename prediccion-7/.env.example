# Configuración del scraper
TARGET_URL=https://ejemplo.com/numeros
SCRAPE_INTERVAL=3600  # segundos entre cada scraping

# Configuración de la base de datos
DATABASE_URL=sqlite:///prediccion.db

# Configuración de Flask
FLASK_ENV=development
SECRET_KEY=tu-clave-secreta-aqui

# Configuración del modelo de predicción
MIN_SAMPLES=50  # Mínimo de muestras para hacer predicciones
PREDICTION_CONFIDENCE=0.7
